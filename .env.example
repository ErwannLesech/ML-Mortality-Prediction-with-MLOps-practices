# Variables d'environnement pour le projet MLOps
# Copiez ce fichier vers .env et ajustez les valeurs selon vos besoins

# Configuration de l'API Flask
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Configuration du logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Configuration des modèles
MODEL_PATH=models/
MODEL_NAME=mortality_model.pkl
PREPROCESSOR_NAME=preprocessor.pkl

# Configuration des données
DATA_PATH=data/
RAW_DATA_PATH=data/raw/
PROCESSED_DATA_PATH=data/processed/

# Configuration de l'évaluation
REPORTS_PATH=reports/
METRICS_THRESHOLD=0.8

# Configuration Docker
DOCKER_IMAGE_NAME=mortality-prediction
DOCKER_TAG=latest

# Configuration de sécurité (à changer en production)
SECRET_KEY=your-secret-key-change-in-production
API_TOKEN=your-api-token-change-in-production

# Configuration des tests
TEST_DATA_SIZE=1000
PYTEST_WORKERS=auto

# Configuration de monitoring (pour production)
MONITORING_ENABLED=False
PROMETHEUS_PORT=9090

# Configuration de base de données (optionnel)
DATABASE_URL=sqlite:///mortality.db

# Configuration de cache (optionnel)
REDIS_URL=redis://localhost:6379/0
